# Auto detect text files and perform LF normalization
* text=auto

# Unity Scene / Prefab
*.unity filter=lfs diff=lfs merge=lfs -text lockable
*.prefab filter=lfs diff=lfs merge=lfs -text lockable

# Animation
*.anim filter=lfs diff=lfs merge=lfs -text lockable
*.controller filter=lfs diff=lfs merge=lfs -text lockable

# Timeline
*.playable filter=lfs diff=lfs merge=lfs -text lockable

# Terrain
*.terrainlayer filter=lfs diff=lfs merge=lfs -text lockable

# FBX / Models
*.fbx filter=lfs diff=lfs merge=lfs -text lockable
*.blend filter=lfs diff=lfs merge=lfs -text lockable

# Audio
*.wav filter=lfs diff=lfs merge=lfs -text lockable
*.mp3 filter=lfs diff=lfs merge=lfs -text lockable
*.ogg filter=lfs diff=lfs merge=lfs -text lockable

# Textures
*.png filter=lfs diff=lfs merge=lfs -text lockable
*.jpg filter=lfs diff=lfs merge=lfs -text lockable
*.tga filter=lfs diff=lfs merge=lfs -text lockable
*.psd filter=lfs diff=lfs merge=lfs -text lockable

# Video
*.mp4 filter=lfs diff=lfs merge=lfs -text lockable